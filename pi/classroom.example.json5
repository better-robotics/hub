// Classroom scoping SPEC — who gets what scope, and why. No longer loaded by
// any binary (2026-07-08): scoping moved from hubd's Rust /ws relay to
// Mosquitto's own ACL, so this file's role changed from runtime config to
// human-readable intent. mosquitto-acl.example.conf + the passwd seeds in
// deploy/install.sh are the mechanical implementation — keep them in sync on
// touch, same split as hub-zenoh's protocol/README (contract) vs
// zenoh-acl.example.json5 (enforcement).
//
// MQTT username IS the identity, and it's always the robot's own name — no
// separate token/robot mapping, so the dashboard can infer scope (all vs.
// one, and which robot) from the username alone (dashboard.html's
// onScope()). No usrpwd rotation: the password is still just "the code IS
// the credential," same idea as a classroom login shared verbally or on a
// slide — now it happens to double as an actual MQTT credential.
{
  professor: { username: "professor", password: "change-me" },

  // The fresh-board pool: every board flashes with this identity (firmware
  // MQTT_USER default) and appears in the dashboard's "Unassigned rovers" card.
  // Deliberately NOT a named robot — no student is given this password, so
  // only the professor (robots/# rw) can drive an unassigned board; the
  // ACL's pattern rule scopes the boards themselves to robots/unassigned/#
  // like any identity.
  pool: { username: "unassigned", password: "unassigned-secret" },

  // Placeholder names — any string works, this is what a student names
  // their robot post-join (CONTRACT.md's cmd/config).
  robots: [
    { username: "robot1", password: "change-me-robot1" },
    { username: "robot2", password: "change-me-robot2" },
  ],
}
