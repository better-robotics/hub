// Zenoh router config for the Pi hub — the MQTT->Zenoh migration's backbone.
// See zenoh-migration.md and better-robotics/hub#9. Staged for the cutover, not
// yet baked into the image (deploy/install.sh installs Mosquitto until then).
//
// Run:  zenohd -c zenoh-router.example.json5
// The storage_manager plugin ships in the official zenoh standalone release
// (the aarch64-unknown-linux-musl asset matches the Pi's static-musl target).
{
  mode: "router",

  // Rovers, the dashboard's WS-JSON adapter, and the MCP bridge all connect
  // here. 0.0.0.0 so every client on the hub AP reaches it via the DHCP gateway
  // (CONTRACT.md discovery: tcp/<gateway>:7447). 7447 is Zenoh's default port.
  listen: { endpoints: ["tcp/0.0.0.0:7447"] },

  // ── Per-owner isolation, router tier (hub#10 step 5) ──────────────────────
  // The ESP hub enforces per-owner claiming because zenoh-pico doesn't route:
  // its WS adapter is the ONLY path a drive command can take. A full router
  // DOES route, so a student's raw Zenoh client on the AP could inject drive
  // straight past the adapter's ownership gate. This ACL restores the ESP tier's
  // property — the adapter is the sole drive path — at the router.
  //
  // A static ACL can't express per-owner rules (ownership is runtime state); it
  // only has to guarantee the adapter is unbypassable. So: DENY writes to the
  // command channels (drive + cmd/* + the e-stop latch) from any AP-radio
  // client. The on-Pi WS adapter connects over LOOPBACK (127.0.0.1) — not an AP
  // radio — so it alone may write them, and it applies per-owner + operator
  // logic before it does. Rovers (on the AP) only SUBSCRIBE to these channels
  // and PUBLISH telemetry (sys/imu/claimable/led-reply), none of which this
  // denies — so nothing a rover actually does is blocked.
  //
  // Interface list is BOTH radios by design: pi/CLAUDE.md § Hub-AP mode — wlan0
  // vs wlan1 is a per-boot driver coin flip, so pinning one would leave the AP
  // un-gated on the boots it lands on the other. Loopback (adapter) and usb0
  // (the bench dev link) are trusted on-Pi/instructor paths, intentionally
  // absent. Zenoh ACL is deny-precedence, which forces this shape — you can only
  // deny the AP subjects, never "allow-only loopback".
  access_control: {
    enabled: true,
    default_permission: "allow",           // open posture — the Wi-Fi perimeter is the boundary
    rules: [
      {
        id: "ap-clients-cannot-write-commands",
        messages: ["put"],
        flows: ["ingress"],
        permission: "deny",
        key_exprs: ["robots/*/pwm", "robots/*/cmd/**", "fleet/estop"],
      },
    ],
    subjects: [
      // Both AP radios — the AP is always one of the two (coin flip); the STA
      // uplink is the other and carries no local Zenoh clients, so denying it is
      // harmless. Loopback + usb0 omitted = allowed (the adapter, the bench).
      { id: "ap-radios", interfaces: ["wlan0", "wlan1"] },
    ],
    policies: [
      { rules: ["ap-clients-cannot-write-commands"], subjects: ["ap-radios"] },
    ],
  },

  plugins: {
    storage_manager: {
      storages: {
        // The fleet/estop latch. A memory (volatile) storage keeps the last
        // value and answers a rebooting rover's join-time query — the
        // retained-message equivalent, with no broker. Volatile = in-memory, so
        // a router restart forgets the latch (= the intended room reset,
        // CONTRACT.md § Fleet e-stop). The rover declares its fleet/estop
        // subscriber, then get()s current state on join; this storage answers.
        estop: { key_expr: "fleet/estop", volume: "memory" },
      },
    },
  },

  // The storage_manager plugin (libzenoh_plugin_storage_manager) must be on the
  // plugin search path — installed beside zenohd, or add:
  //   plugins_loading: { enabled: true, search_dirs: ["/usr/lib/zenoh"] },
}
