// Classroom scoping SPEC — who gets what scope, and why. No longer loaded by
// any binary (2026-07-08): scoping moved from hubd's Rust /ws relay to
// Mosquitto's own ACL, so this file's role changed from runtime config to
// human-readable intent. mosquitto-acl.example.conf + mosquitto-passwd.example
// are the mechanical implementation — keep all three in sync on touch, same
// split as hub-zenoh's protocol/README (contract) vs zenoh-acl.example.json5
// (enforcement).
//
// MQTT username IS the identity, and for a team it's always that team's robot
// id — no separate token/robot mapping, so the dashboard can infer scope
// (all vs. one, and which robot) from the username alone (dashboard.html's
// onScope()). No usrpwd rotation: the password is still just "the code IS
// the credential," same idea as a classroom login shared verbally or on a
// slide — now it happens to double as an actual MQTT credential.
{
  professor: { username: "professor", password: "change-me" },

  teams: [
    { username: "team1", password: "change-me-team1" },
    { username: "team2", password: "change-me-team2" },
  ],
}
