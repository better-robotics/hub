esp32/build/
esp32/managed_components/
esp32/sdkconfig
esp32/sdkconfig.old
esp32/dependencies.lock
esp32/main/wifi_creds.h              # REAL venue Wi-Fi creds — NEVER commit (see wifi_creds.example.h)

